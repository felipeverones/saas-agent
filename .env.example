# Copy to `.env` and fill in real values. NEVER commit `.env` (it's gitignored).
# Every variable here is loaded and validated by src/nimbusdesk/infrastructure/settings.py
# via pydantic-settings — if a required var is missing, the app fails AT STARTUP with a
# clear error instead of crashing mid-request.

# --- LLM (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Strong model for reasoning-heavy agents (technical support, supervisor decisions)
NIMBUS_MODEL_STRONG=claude-sonnet-5
# Cheap/fast model for high-volume, low-stakes steps (triage classification, query rewriting)
NIMBUS_MODEL_FAST=claude-haiku-4-5-20251001

# --- Vector store (Qdrant, runs via docker compose) ---
QDRANT_URL=http://localhost:6333

# --- Observability (Arize Phoenix, runs via docker compose) ---
# OTLP gRPC endpoint where OpenTelemetry spans are exported (phase 8)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- MCP servers (phase 5) ---
MCP_CRM_URL=http://localhost:8101/mcp
MCP_TICKETING_URL=http://localhost:8102/mcp
